{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if section.blocks.size > 0 -%}
<section class="press-strip color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
         aria-label="Press and credentials">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="press-strip__heading caption-with-letter-spacing">
        {{- section.settings.heading | escape -}}
      </p>
    {%- endif -%}
    <ul class="press-strip__list" role="list">
      {%- for block in section.blocks -%}
        <li class="press-strip__item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="press-strip__link"
               target="_blank" rel="noopener" aria-label="{{ block.settings.alt | escape }}">
          {%- endif -%}
          {%- if block.settings.image != blank -%}
            {%- assign press_logo_alt = block.settings.alt | default: block.settings.image.alt | escape -%}
            {{
              block.settings.image
              | image_url: width: 560
              | image_tag:
                loading: 'lazy',
                widths: '120, 160, 240, 320, 400, 560',
                sizes: '(min-width: 750px) 200px, 42vw',
                alt: press_logo_alt,
                class: 'press-strip__logo'
            }}
          {%- elsif block.settings.text != blank -%}
            <span class="press-strip__text-logo">{{ block.settings.text | escape }}</span>
          {%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>
{%- endif -%}

<style>
  .press-strip__heading {
    text-align: center; margin-bottom: 2.4rem;
    opacity: 0.55; letter-spacing: 0.15em;
    text-transform: uppercase; font-size: 1.1rem;
  }
  .press-strip__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: center;
    justify-items: center;
    gap: 2.8rem 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 42rem;
    margin-inline: auto;
  }
  .press-strip__item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .press-strip__logo {
    display: block;
    width: auto;
    height: auto;
    max-height: 3.2rem;
    max-width: min(100%, 14rem);
    filter: grayscale(1);
    opacity: 0.55;
    transition: opacity 0.2s ease;
  }
  .press-strip__item:hover .press-strip__logo { opacity: 0.85; }
  .press-strip__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    text-decoration: none;
  }
  .press-strip__text-logo {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    font-style: italic;
    opacity: 0.55;
    letter-spacing: 0.05em;
    text-align: center;
  }
  @media screen and (min-width: 750px) {
    .press-strip__list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 2.4rem 3.2rem;
      max-width: 100%;
    }
    .press-strip__logo {
      max-height: 4.8rem;
      max-width: min(100%, 18rem);
    }
    .press-strip__text-logo {
      font-size: 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Press strip",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Eyebrow heading", "default": "Inspired by Timeless Interiors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding top", "default": 28 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding bottom", "default": 28 }
  ],
  "blocks": [
    {
      "type": "press_logo",
      "name": "Logo / publication",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo image" },
        { "type": "text", "id": "text", "label": "Text fallback (if no image)" },
        { "type": "text", "id": "alt", "label": "Publication name" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press strip",
      "blocks": [
        { "type": "press_logo", "settings": { "text": "Architectural Digest", "alt": "Architectural Digest" } },
        { "type": "press_logo", "settings": { "text": "House Beautiful", "alt": "House Beautiful" } },
        { "type": "press_logo", "settings": { "text": "Elle Decor", "alt": "Elle Decor" } }
      ]
    }
  ]
}
{% endschema %}
