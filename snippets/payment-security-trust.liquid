{% comment %}
  Payment & Security row — lists shop-enabled payment types (same source as footer).
  Usage: {% render 'payment-security-trust' %}
{% endcomment %}
{%- if shop.enabled_payment_types.size > 0 -%}
  <div class="payment-security-trust">
    <div class="payment-security-trust__heading">
      <span class="payment-security-trust__icon svg-wrapper" aria-hidden="true">
        {{- 'icon-lock.svg' | inline_asset_content -}}
      </span>
      <span class="payment-security-trust__title">{{ 'products.product.payment_security.heading' | t }}</span>
    </div>
    <span class="visually-hidden">{{ 'products.product.payment_security.methods_label' | t }}</span>
    <ul class="payment-security-trust__icons list-unstyled" role="list">
      {%- for type in shop.enabled_payment_types -%}
        <li class="payment-security-trust__item">
          {{ type | payment_type_svg_tag: class: 'payment-security-trust__badge icon icon--full-color' }}
        </li>
      {%- endfor -%}
    </ul>
  </div>
{%- endif -%}
