{% comment %}
  Outputs rgb(...) for common finish/color labels when catalog swatches are not configured.
  Pass: color_label — option value display name.
{% endcomment %}
{%- liquid
  assign vn = color_label | strip | downcase
  assign out = ''
  assign vn = vn | replace: '”', '"' | replace: '"', ''
  assign vn = vn | split: '/' | first | strip

  case vn
    when 'brown'
      assign out = 'rgb(101, 67, 33)'
    when 'walnut'
      assign out = 'rgb(92, 64, 51)'
    when 'oak'
      assign out = 'rgb(191, 159, 121)'
    when 'black'
      assign out = 'rgb(33, 33, 33)'
    when 'matte black'
      assign out = 'rgb(33, 33, 33)'
    when 'jet black'
      assign out = 'rgb(33, 33, 33)'
    when 'white'
      assign out = 'rgb(245, 245, 240)'
    when 'matte white'
      assign out = 'rgb(245, 245, 240)'
    when 'off white'
      assign out = 'rgb(245, 245, 240)'
    when 'off-white'
      assign out = 'rgb(245, 245, 240)'
    when 'natural'
      assign out = 'rgb(214, 184, 148)'
    when 'natural wood'
      assign out = 'rgb(214, 184, 148)'
    when 'unfinished'
      assign out = 'rgb(214, 184, 148)'
    when 'raw'
      assign out = 'rgb(214, 184, 148)'
    when 'gray'
      assign out = 'rgb(115, 115, 115)'
    when 'grey'
      assign out = 'rgb(115, 115, 115)'
    when 'charcoal'
      assign out = 'rgb(80, 80, 80)'
    when 'slate'
      assign out = 'rgb(115, 115, 115)'
    when 'cherry'
      assign out = 'rgb(139, 58, 58)'
    when 'maple'
      assign out = 'rgb(235, 214, 182)'
    when 'espresso'
      assign out = 'rgb(54, 37, 27)'
    when 'mahogany'
      assign out = 'rgb(92, 42, 42)'
    when 'teak'
      assign out = 'rgb(141, 110, 82)'
    when 'beech'
      assign out = 'rgb(212, 176, 137)'
    when 'birch'
      assign out = 'rgb(227, 218, 201)'
    when 'pine'
      assign out = 'rgb(223, 195, 145)'
    when 'cedar'
      assign out = 'rgb(175, 132, 96)'
    when 'ash'
      assign out = 'rgb(189, 174, 154)'
    when 'beige'
      assign out = 'rgb(220, 205, 184)'
    when 'sand'
      assign out = 'rgb(220, 205, 184)'
    when 'taupe'
      assign out = 'rgb(220, 205, 184)'
    when 'cream'
      assign out = 'rgb(245, 240, 230)'
    when 'ivory'
      assign out = 'rgb(255, 255, 240)'
    when 'honey'
      assign out = 'rgb(198, 154, 92)'
    when 'pecan'
      assign out = 'rgb(120, 81, 52)'
    when 'navy'
      assign out = 'rgb(26, 43, 72)'
    when 'navy blue'
      assign out = 'rgb(26, 43, 72)'
    when 'blue'
      assign out = 'rgb(52, 96, 148)'
    when 'green'
      assign out = 'rgb(58, 110, 72)'
    when 'red'
      assign out = 'rgb(156, 42, 42)'
    when 'yellow'
      assign out = 'rgb(212, 175, 55)'
    when 'gold'
      assign out = 'rgb(212, 175, 55)'
    when 'silver'
      assign out = 'rgb(180, 184, 188)'
    when 'brass'
      assign out = 'rgb(176, 132, 72)'
    when 'copper'
      assign out = 'rgb(176, 132, 72)'
    when 'đen'
      assign out = 'rgb(33, 33, 33)'
    when 'màu đen'
      assign out = 'rgb(33, 33, 33)'
    when 'trắng'
      assign out = 'rgb(245, 245, 240)'
    when 'màu trắng'
      assign out = 'rgb(245, 245, 240)'
    when 'nâu'
      assign out = 'rgb(101, 67, 33)'
    when 'màu nâu'
      assign out = 'rgb(101, 67, 33)'
    when 'gỗ sồi'
      assign out = 'rgb(191, 159, 121)'
    when 'sồi'
      assign out = 'rgb(191, 159, 121)'
    when 'óc chó'
      assign out = 'rgb(92, 64, 51)'
  endcase
-%}
{{- out -}}
